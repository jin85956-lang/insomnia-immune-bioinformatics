# ============================================================
# .gitignore for an R bioinformatics project
# ============================================================
# Keep this repo small (< 100 MB total). Large data files belong
# on Zenodo as a separate data deposit, not in the code repo.

# ---- R / RStudio temp files ----
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
.Rapp.history

# ---- R data caches and intermediate results ----
# Do NOT commit large .RData / .rds — they can be regenerated by the code.
*.RData
*.Rdata
*.rds

# ---- Bulk downloads (these will be downloaded fresh by the code) ----
# GEO SOFT/MINiML files
*_series_matrix.txt.gz
*_family.soft.gz
*_family.xml.tgz
GSE*/

# eQTLGen (~308 MB)
cis-eQTLsFDR*.txt.gz
*-cis-eQTLs*.txt.gz

# Jansen 2019 GWAS (~1.3 GB)
Insomnia_sumstats_Jansenetal.txt.gz
Jansen2019_insomnia.zip
*.ma

# SMR intermediates
*.besd
*.epi
*.esi
*.smr
trait_*.tsv
trait_*.zip

# CIBERSORTx outputs
CIBERSORTx_Job*_Results.csv
CIBERSORTx_*_inferred*.txt
mixture_*.txt

# 1000 Genomes LD reference
g1000_eur.*
EUR.*.bed
EUR.*.bim
EUR.*.fam

# ---- Generated figures / tables (regenerable) ----
# If you want to ship final figures, comment these out.
figures/*.pdf
figures/*.png
figures/*.tiff
*.xlsx

# ---- OS clutter ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Logs ----
*.log
nohup.out
